<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="Terminals"
      focusComponent="terminalsDataGrid">
    <data>
        <collection id="terminalsDc"
                    class="com.digtp.scm.entity.Terminal">
            <fetchPlan extends="_base"/>
            <loader id="terminalsDl" readOnly="true">
                <query>
                    <![CDATA[select e from scm_Terminal e order by e.name]]>
                </query>
            </loader>
        </collection>
    </data>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <layout>
        <dataGrid id="terminalsDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="terminalsDc">
            <columns>
                <column property="code" header="Code"/>
                <column property="name" header="Name"/>
                <column property="port" header="Port"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
