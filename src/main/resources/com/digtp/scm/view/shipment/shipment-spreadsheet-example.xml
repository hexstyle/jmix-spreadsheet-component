<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!--
    Example XML view showing how to use SpreadsheetComponent.
    
    This example demonstrates:
    - Defining a CollectionContainer in the data section
    - Binding the spreadsheet to the container via dataContainer attribute
    - Basic component attributes (id, width, height)
    
    NOTE: This is a minimal example. Future enhancements will support:
    - Column configuration via <columns> element
    - Pivot configuration via <pivot> element
-->
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:spreadsheet="http://jmix.io/schema/spreadsheet"
      title="msg://ShipmentSpreadsheetView.title"
      focusComponent="shipmentsSpreadsheet">
    <data>
        <collection id="shipmentsDc"
                    class="com.digtp.scm.entity.Shipment">
            <fetchPlan extends="_base"/>
            <loader id="shipmentsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Shipment e order by e.day desc]]>
                </query>
            </loader>
        </collection>
    </data>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="shipmentsDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <endSlot>
                <simplePagination id="pagination" dataLoader="shipmentsDl"/>
            </endSlot>
        </hbox>
        <!-- Spreadsheet component -->
        <spreadsheet:spreadsheet id="shipmentsSpreadsheet"
                                 dataContainer="shipmentsDc"
                                 width="100%"
                                 height="100%"
                                 minHeight="20em"/>
    </layout>
</view>
