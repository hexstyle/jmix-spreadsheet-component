<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Create Plant table -->
    <changeSet id="1" author="jmix-spreadsheet" context="!cuba">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="PLANT"/>
            </not>
        </preConditions>
        <createTable tableName="PLANT">
            <column name="ID" type="${uuid.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="VERSION" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Create Product table -->
    <changeSet id="2" author="jmix-spreadsheet" context="!cuba">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="PRODUCT"/>
            </not>
        </preConditions>
        <createTable tableName="PRODUCT">
            <column name="ID" type="${uuid.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="VERSION" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Create Vessel table -->
    <changeSet id="3" author="jmix-spreadsheet" context="!cuba">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="VESSEL"/>
            </not>
        </preConditions>
        <createTable tableName="VESSEL">
            <column name="ID" type="${uuid.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="VERSION" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Insert Plant entities from enum values -->
    <changeSet id="4" author="jmix-spreadsheet" context="!cuba">
        <sql>
            INSERT INTO PLANT (ID, VERSION, NAME) VALUES
            ('00000000-0000-0000-0000-000000000001', 1, 'Plant A'),
            ('00000000-0000-0000-0000-000000000002', 1, 'Plant B'),
            ('00000000-0000-0000-0000-000000000003', 1, 'Plant C'),
            ('00000000-0000-0000-0000-000000000004', 1, 'Plant D'),
            ('00000000-0000-0000-0000-000000000005', 1, 'Plant E');
        </sql>
    </changeSet>

    <!-- Insert Product entities from enum values -->
    <changeSet id="5" author="jmix-spreadsheet" context="!cuba">
        <sql>
            INSERT INTO PRODUCT (ID, VERSION, NAME) VALUES
            ('00000000-0000-0000-0000-000000000101', 1, 'Product 1'),
            ('00000000-0000-0000-0000-000000000102', 1, 'Product 2'),
            ('00000000-0000-0000-0000-000000000103', 1, 'Product 3'),
            ('00000000-0000-0000-0000-000000000104', 1, 'Product 4'),
            ('00000000-0000-0000-0000-000000000105', 1, 'Product 5'),
            ('00000000-0000-0000-0000-000000000106', 1, 'Product 6'),
            ('00000000-0000-0000-0000-000000000107', 1, 'Product 7'),
            ('00000000-0000-0000-0000-000000000108', 1, 'Product 8'),
            ('00000000-0000-0000-0000-000000000109', 1, 'Product 9'),
            ('00000000-0000-0000-0000-00000000010a', 1, 'Product 10');
        </sql>
    </changeSet>

    <!-- Insert Vessel entities from enum values -->
    <changeSet id="6" author="jmix-spreadsheet" context="!cuba">
        <sql>
            INSERT INTO VESSEL (ID, VERSION, NAME) VALUES
            ('00000000-0000-0000-0000-000000000201', 1, 'Vessel 1'),
            ('00000000-0000-0000-0000-000000000202', 1, 'Vessel 2'),
            ('00000000-0000-0000-0000-000000000203', 1, 'Vessel 3'),
            ('00000000-0000-0000-0000-000000000204', 1, 'Vessel 4'),
            ('00000000-0000-0000-0000-000000000205', 1, 'Vessel 5');
        </sql>
    </changeSet>

    <!-- Add foreign key columns to SHIPMENT -->
    <changeSet id="7" author="jmix-spreadsheet" context="!cuba">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="SHIPMENT" columnName="PLANT_ID"/>
            </not>
        </preConditions>
        <addColumn tableName="SHIPMENT">
            <column name="PLANT_ID" type="${uuid.type}"/>
        </addColumn>
        <addColumn tableName="SHIPMENT">
            <column name="PRODUCT_ID" type="${uuid.type}"/>
        </addColumn>
        <addColumn tableName="SHIPMENT">
            <column name="VESSEL_ID" type="${uuid.type}"/>
        </addColumn>
    </changeSet>

    <!-- Migrate existing enum data to foreign keys -->
    <changeSet id="8" author="jmix-spreadsheet" context="!cuba">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="SHIPMENT" columnName="PLANT"/>
        </preConditions>
        <sql>
            UPDATE SHIPMENT SET PLANT_ID = '00000000-0000-0000-0000-000000000001' WHERE PLANT = 'PLANT_A';
            UPDATE SHIPMENT SET PLANT_ID = '00000000-0000-0000-0000-000000000002' WHERE PLANT = 'PLANT_B';
            UPDATE SHIPMENT SET PLANT_ID = '00000000-0000-0000-0000-000000000003' WHERE PLANT = 'PLANT_C';
            UPDATE SHIPMENT SET PLANT_ID = '00000000-0000-0000-0000-000000000004' WHERE PLANT = 'PLANT_D';
            UPDATE SHIPMENT SET PLANT_ID = '00000000-0000-0000-0000-000000000005' WHERE PLANT = 'PLANT_E';
        </sql>
    </changeSet>

    <changeSet id="9" author="jmix-spreadsheet" context="!cuba">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="SHIPMENT" columnName="PRODUCT_"/>
        </preConditions>
        <sql>
            UPDATE SHIPMENT SET PRODUCT_ID = '00000000-0000-0000-0000-000000000101' WHERE PRODUCT_ = 'PRODUCT_1';
            UPDATE SHIPMENT SET PRODUCT_ID = '00000000-0000-0000-0000-000000000102' WHERE PRODUCT_ = 'PRODUCT_2';
            UPDATE SHIPMENT SET PRODUCT_ID = '00000000-0000-0000-0000-000000000103' WHERE PRODUCT_ = 'PRODUCT_3';
            UPDATE SHIPMENT SET PRODUCT_ID = '00000000-0000-0000-0000-000000000104' WHERE PRODUCT_ = 'PRODUCT_4';
            UPDATE SHIPMENT SET PRODUCT_ID = '00000000-0000-0000-0000-000000000105' WHERE PRODUCT_ = 'PRODUCT_5';
            UPDATE SHIPMENT SET PRODUCT_ID = '00000000-0000-0000-0000-000000000106' WHERE PRODUCT_ = 'PRODUCT_6';
            UPDATE SHIPMENT SET PRODUCT_ID = '00000000-0000-0000-0000-000000000107' WHERE PRODUCT_ = 'PRODUCT_7';
            UPDATE SHIPMENT SET PRODUCT_ID = '00000000-0000-0000-0000-000000000108' WHERE PRODUCT_ = 'PRODUCT_8';
            UPDATE SHIPMENT SET PRODUCT_ID = '00000000-0000-0000-0000-000000000109' WHERE PRODUCT_ = 'PRODUCT_9';
            UPDATE SHIPMENT SET PRODUCT_ID = '00000000-0000-0000-0000-00000000010a' WHERE PRODUCT_ = 'PRODUCT_10';
        </sql>
    </changeSet>

    <changeSet id="10" author="jmix-spreadsheet" context="!cuba">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="SHIPMENT" columnName="VESSEL"/>
        </preConditions>
        <sql>
            UPDATE SHIPMENT SET VESSEL_ID = '00000000-0000-0000-0000-000000000201' WHERE VESSEL = 'VESSEL_1';
            UPDATE SHIPMENT SET VESSEL_ID = '00000000-0000-0000-0000-000000000202' WHERE VESSEL = 'VESSEL_2';
            UPDATE SHIPMENT SET VESSEL_ID = '00000000-0000-0000-0000-000000000203' WHERE VESSEL = 'VESSEL_3';
            UPDATE SHIPMENT SET VESSEL_ID = '00000000-0000-0000-0000-000000000204' WHERE VESSEL = 'VESSEL_4';
            UPDATE SHIPMENT SET VESSEL_ID = '00000000-0000-0000-0000-000000000205' WHERE VESSEL = 'VESSEL_5';
        </sql>
    </changeSet>

    <!-- Make foreign key columns NOT NULL -->
    <changeSet id="11" author="jmix-spreadsheet" context="!cuba">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="SHIPMENT" columnName="PLANT_ID"/>
            <not>
                <columnExists tableName="SHIPMENT" columnName="PLANT"/>
            </not>
        </preConditions>
        <addNotNullConstraint tableName="SHIPMENT" columnName="PLANT_ID" columnDataType="${uuid.type}"/>
        <addNotNullConstraint tableName="SHIPMENT" columnName="PRODUCT_ID" columnDataType="${uuid.type}"/>
        <addNotNullConstraint tableName="SHIPMENT" columnName="VESSEL_ID" columnDataType="${uuid.type}"/>
    </changeSet>

    <!-- Add foreign key constraints -->
    <changeSet id="12" author="jmix-spreadsheet" context="!cuba">
        <addForeignKeyConstraint baseTableName="SHIPMENT"
                                 baseColumnNames="PLANT_ID"
                                 constraintName="FK_SHIPMENT_PLANT"
                                 referencedTableName="PLANT"
                                 referencedColumnNames="ID"/>
        <addForeignKeyConstraint baseTableName="SHIPMENT"
                                 baseColumnNames="PRODUCT_ID"
                                 constraintName="FK_SHIPMENT_PRODUCT"
                                 referencedTableName="PRODUCT"
                                 referencedColumnNames="ID"/>
        <addForeignKeyConstraint baseTableName="SHIPMENT"
                                 baseColumnNames="VESSEL_ID"
                                 constraintName="FK_SHIPMENT_VESSEL"
                                 referencedTableName="VESSEL"
                                 referencedColumnNames="ID"/>
    </changeSet>

    <!-- Drop old enum columns -->
    <changeSet id="13" author="jmix-spreadsheet" context="!cuba">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="SHIPMENT" columnName="PLANT"/>
        </preConditions>
        <dropColumn tableName="SHIPMENT" columnName="PLANT"/>
        <dropColumn tableName="SHIPMENT" columnName="PRODUCT_"/>
        <dropColumn tableName="SHIPMENT" columnName="VESSEL"/>
    </changeSet>

</databaseChangeLog>
