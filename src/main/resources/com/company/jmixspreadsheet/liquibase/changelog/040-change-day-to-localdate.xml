<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="jmix-spreadsheet" context="!cuba">
        <comment>Change DAY_ column from timestamp to date (remove time component)</comment>
        
        <!-- For HSQLDB, we can use modifyDataType, but need to handle data conversion -->
        <!-- For PostgreSQL, we use ALTER COLUMN ... TYPE date -->
        <sql dbms="postgresql">
            ALTER TABLE SHIPMENT ALTER COLUMN DAY_ TYPE date USING DAY_::date;
        </sql>
        
        <!-- For H2 -->
        <sql dbms="h2">
            ALTER TABLE SHIPMENT ALTER COLUMN DAY_ DATE;
        </sql>
        
        <!-- For HSQLDB -->
        <sql dbms="hsqldb">
            ALTER TABLE SHIPMENT ALTER COLUMN DAY_ DATE;
        </sql>
    </changeSet>

</databaseChangeLog>
