<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="jmix-spreadsheet" context="!cuba">
        <createTable tableName="SHIPMENT">
            <column name="ID" type="${uuid.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="VERSION" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="DAY_" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="PLANT" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="PRODUCT_" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="VESSEL" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="VALUE_" type="decimal(19, 2)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="jmix-spreadsheet" context="!cuba">
        <createIndex indexName="IDX_SHIPMENT_ON_DAY"
                     tableName="SHIPMENT">
            <column name="DAY_"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
