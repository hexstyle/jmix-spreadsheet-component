<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://ShipmentListView.title"
      focusComponent="shipmentsDataGrid">
    <data>
        <collection id="shipmentsDc"
                    class="com.company.jmixspreadsheet.entity.Shipment">
            <fetchPlan extends="_base"/>
            <loader id="shipmentsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Shipment e order by e.day desc]]>
                </query>
            </loader>
        </collection>

    </data>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="shipmentsDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="shipmentsDataGrid.createAction"/>
                <button id="editButton" action="shipmentsDataGrid.editAction"/>
                <button id="removeButton" action="shipmentsDataGrid.removeAction"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="shipmentsDl"/>
            </endSlot>
        </hbox>
        <dataGrid id="shipmentsDataGrid"
                  width="100%"
                  columnReorderingAllowed="true"
                  minHeight="20em"
                  dataContainer="shipmentsDc">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
