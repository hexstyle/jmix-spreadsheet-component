<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://ShipmentDetailView.title"
      focusComponent="form">
    <data>
        <instance id="shipmentDc"
                  class="com.company.jmixspreadsheet.entity.Shipment">
            <fetchPlan extends="_base"/>
            <loader/>
        </instance>
    </data>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <layout>
        <formLayout id="form" dataContainer="shipmentDc">
            <dateTimePicker id="dayField" property="day" required="true"/>
            <comboBox id="plantField" property="plant" required="true"/>
            <comboBox id="productField" property="product" required="true"/>
            <comboBox id="vesselField" property="vessel" required="true"/>
            <textField id="valueField" property="value" required="true"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
