<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://ShipmentSpreadsheetView.title"
      xmlns:spreadsheet="http://com.company/spreadsheet.xsd"
      focusComponent="shipmentsSpreadsheet">
    <data>
        <collection id="shipmentsDc"
                    class="com.company.jmixspreadsheet.entity.Shipment">
            <fetchPlan extends="_base"/>
            <loader id="shipmentsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Shipment e order by e.day desc]]>
                </query>
            </loader>
        </collection>

    </data>
    <facets>
        <dataLoadCoordinator auto="false"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="shipmentsDl">
            <properties include="day"/>
            <configurations>
                <configuration id="defaultConfiguration" name="Date Range Filter"
                               default="true">
                    <propertyFilter property="day" operation="GREATER_OR_EQUAL"
                                    operationEditable="false"/>
                    <propertyFilter property="day" operation="LESS_OR_EQUAL"
                                    operationEditable="false"/>
                </configuration>
            </configurations>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <endSlot>
                <simplePagination id="pagination" dataLoader="shipmentsDl"/>
            </endSlot>
        </hbox>
        <spreadsheet:spreadsheet id="shipmentsSpreadsheet"
                     width="100%"
                     height="100%"
                     minHeight="20em"/>
    </layout>
</view>
