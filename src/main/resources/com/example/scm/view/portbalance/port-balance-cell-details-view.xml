<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="Port balance details">
    <data>
        <collection id="plantShipmentReasonsDc"
                    class="com.example.scm.entity.PlantShipmentReason">
            <fetchPlan extends="_base"/>
        </collection>
        <collection id="vesselLoadItemsDc"
                    class="com.example.scm.entity.VesselLoadItem">
            <fetchPlan extends="_base"/>
        </collection>
        <collection id="vesselLoadsDc"
                    class="com.example.scm.entity.VesselLoad">
            <fetchPlan extends="_base"/>
        </collection>
    </data>
    <layout>
        <vbox spacing="true">
            <label id="plantShipmentsLabel" text="Plant shipments"/>
            <dataGrid id="plantShipmentGrid"
                      dataContainer="plantShipmentReasonsDc"
                      height="14em">
                <columns>
                    <column property="date"/>
                    <column property="volume"/>
                    <column property="leadtime"/>
                    <column property="track"/>
                </columns>
            </dataGrid>
            <label id="vesselLoadItemsLabel" text="Vessel load items"/>
            <dataGrid id="vesselLoadItemGrid"
                      dataContainer="vesselLoadItemsDc"
                      height="14em">
                <columns>
                    <column property="vesselLoad"/>
                    <column property="preParty"/>
                    <column property="volume"/>
                </columns>
            </dataGrid>
            <label id="vesselLoadsLabel" text="Vessel loads"/>
            <dataGrid id="vesselLoadGrid"
                      dataContainer="vesselLoadsDc"
                      height="14em">
                <columns>
                    <column property="vesselName"/>
                    <column property="terminal"/>
                    <column property="planningLaycanStartDate"/>
                    <column property="planningLaycanEndDate"/>
                    <column property="actualLaycanStartDate"/>
                    <column property="actualLaycanEndDate"/>
                </columns>
            </dataGrid>
        </vbox>
    </layout>
</view>
