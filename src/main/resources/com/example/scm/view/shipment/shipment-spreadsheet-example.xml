<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:spreadsheet="http://com.company/spreadsheet.xsd"
      title="msg://ShipmentSpreadsheetExampleView.title"
      focusComponent="movementsSpreadsheet">
    <data>
        <collection id="movementsDc"
                    class="com.example.scm.entity.Movement">
            <fetchPlan extends="_base">
                <property name="track" fetchPlan="_base"/>
                <property name="warehouse" fetchPlan="_base">
                    <property name="terminal" fetchPlan="_base"/>
                </property>
                <property name="product" fetchPlan="_base"/>
                <property name="originPlant" fetchPlan="_base"/>
                <property name="productPackage" fetchPlan="_base"/>
                <property name="reason" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="movementsDl" readOnly="true">
                <query>
                    <![CDATA[
                        select m from scm_Movement m
                        order by m.date desc, m.track.name, m.warehouse.terminal.name
                    ]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <layout>
        <vbox id="developerHelp" spacing="false">
            <h4 text="How to configure this example"/>
            <label text="1) Keep query in XML loader and bind spreadsheet to dataLoader=movementsDl."/>
            <label text="2) Only purple Value cells are editable. All headers and non-Value cells revert to old value."/>
            <label text="3) Value accepts only numeric input. Invalid input is rejected and shown in edit log."/>
            <label text="4) Spreadsheet edit event contains date, cell address, entity class/id, old/new values, success and error."/>
            <label text="5) Edit log below is filled from Spreadsheet interaction handler (onCellEdit)."/>
        </vbox>
        <textArea id="editLogField"
                  width="100%"
                  minHeight="10em"
                  maxHeight="14em"
                  label="Edit log"
                  readOnly="true"/>
        <spreadsheet:spreadsheet id="movementsSpreadsheet"
                                 dataLoader="movementsDl"
                                 width="100%"
                                 height="100%"
                                 minHeight="26em"
                                 headerStyle="background-color:#E0ECFF;color:#102A43;font-weight:700;"/>
    </layout>
</view>
