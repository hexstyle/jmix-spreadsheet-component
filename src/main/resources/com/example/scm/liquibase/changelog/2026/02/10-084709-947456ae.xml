    <changeSet id="1" author="jmix-spreadsheet">
        <createTable tableName="SCM_REASON">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_SCM_REASON"/>
            </column>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
            <column name="LAST_MODIFIED_BY" type="VARCHAR(255)"/>
            <column name="LAST_MODIFIED_DATE" type="${offsetDateTime.type}"/>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="${offsetDateTime.type}"/>
            <column name="WAREHOUSE_ID" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="COUNTERPARTY_WAREHOUSE_ID" type="UUID"/>
            <column name="PRODUCT_ID" type="UUID"/>
            <column name="PRODUCT_PACKAGE_ID" type="UUID"/>
            <column name="ORIGIN_PLANT_ID" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="DATE_" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="VOLUME" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="TRACK_ID" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="COMMENT_" type="VARCHAR(2000)"/>
            <column name="IS_FACT" type="BOOLEAN"/>
            <column name="PARENT_REASON_ID" type="UUID"/>
            <column name="USER_ID" type="UUID"/>
            <column name="LEADTIME" type="SMALLINT"/>
            <column name="TRANSPORT_TYPE_ID" type="UUID"/>
            <column name="VESSEL_LOAD_ITEM_ID" type="UUID"/>
            <column name="DTYPE" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
